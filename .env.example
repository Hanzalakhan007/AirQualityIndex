# Core location settings
AQI_CITY=Karachi
AQI_LAT=24.8607
AQI_LON=67.0011
AQI_TIMEZONE=Asia/Karachi

# Backward-compatible aliases
LAT=24.8607
LON=67.0011

# API keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# MongoDB feature store and model registry
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=air_quality_index
MONGO_FEATURES_COLLECTION=aqi_features
MONGO_MODEL_REGISTRY_COLLECTION=model_registry
MONGO_MODEL_BUCKET=model_artifacts

# AQI behavior
USE_OPENMETEO_AQI=true
AQI_SCALE_1_5=false
KARACHI_REFERENCE_AQI=96.0
AQI_CALIBRATION_ENABLED=true
